{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wasm:build": "wasm-pack build ../engine --target web --out-dir ../web/pkg",
    "dev": "npm run wasm:build && vite",
    "build": "npm run wasm:build && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\"",
    "lint:rs": "cargo clippy --manifest-path ../engine/Cargo.toml --target wasm32-unknown-unknown -- -D warnings",
    "fmt:rs": "cargo fmt --manifest-path ../engine/Cargo.toml",
    "fmt:rs:check": "cargo fmt --manifest-path ../engine/Cargo.toml -- --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  }
}
